---
const features = [
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
    labelDe: '90m² Wohnfläche', labelEn: '90m² Living Space',
    descDe: 'Großzügiges Apartment', descEn: 'Spacious apartment',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>`,
    labelDe: 'Naturblick', labelEn: 'Nature View',
    descDe: 'Idyllische Aussicht', descEn: 'Idyllic panorama',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    labelDe: '6 Gäste', labelEn: '6 Guests',
    descDe: 'Bis zu 6 Personen', descEn: 'Up to 6 people',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>`,
    labelDe: 'Self Check-in', labelEn: 'Self Check-in',
    descDe: 'Flexibel ankommen', descEn: 'Arrive anytime',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0"/></svg>`,
    labelDe: 'WLAN 150 Mbit', labelEn: 'WiFi 150 Mbit',
    descDe: 'Ultraschnelles Internet', descEn: 'Ultra-fast internet',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>`,
    labelDe: 'Parkplatz', labelEn: 'Free Parking',
    descDe: 'Kostenlos vor Ort', descEn: 'Free on-site',
  },
];
---

<section id="features" class="py-20 px-4 bg-white dark:bg-stone-900/30">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <span class="inline-block text-[#FF5A5F] text-sm font-semibold tracking-widest uppercase mb-3">
        <span data-de>Ausstattung</span>
        <span data-en>Amenities</span>
      </span>
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-stone-900 dark:text-white">
        <span data-de>Alles was Sie brauchen</span>
        <span data-en>Everything you need</span>
      </h2>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 sm:gap-5">
      {features.map((f) => (
        <div class="group bg-stone-50 dark:bg-stone-900 border border-stone-100 dark:border-stone-800 rounded-2xl p-5 sm:p-6 flex flex-col items-center text-center gap-3 hover:border-[#FF5A5F]/40 hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
          <div class="w-14 h-14 rounded-2xl bg-red-50 dark:bg-red-900/20 flex items-center justify-center text-[#FF5A5F] group-hover:bg-red-100 dark:group-hover:bg-red-900/30 transition-colors">
            <Fragment set:html={f.icon} />
          </div>
          <div>
            <p class="font-semibold text-stone-800 dark:text-white text-sm sm:text-base">
              <span data-de>{f.labelDe}</span>
              <span data-en>{f.labelEn}</span>
            </p>
            <p class="text-stone-400 dark:text-stone-500 text-xs sm:text-sm mt-0.5">
              <span data-de>{f.descDe}</span>
              <span data-en>{f.descEn}</span>
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
