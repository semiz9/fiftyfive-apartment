---
---
<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 dark:bg-stone-950/95 backdrop-blur-md border-b border-stone-100 dark:border-stone-800 shadow-sm">
  <div class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">

    <!-- Logo + Name -->
    <a href="#hero" class="flex items-center gap-2.5 group">
      <!-- House logo SVG matching the provided logo -->
      <svg class="w-8 h-8 flex-shrink-0" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M22 4L40 17V42H4V17L22 4Z" stroke="#222" stroke-width="2.2" stroke-linejoin="round"
              class="dark:stroke-white"/>
        <text x="22" y="30" font-family="Inter,sans-serif" font-size="13" font-weight="700"
              fill="#222" text-anchor="middle" class="dark:fill-white" dominant-baseline="auto">55</text>
        <path d="M14 35.5L18 39L28 30" stroke="#222" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              class="dark:stroke-white"/>
      </svg>
      <span class="font-bold text-stone-900 dark:text-white text-[15px] tracking-tight group-hover:text-[#FF5A5F] transition-colors">
        Fiftyfive Apartments
      </span>
    </a>

    <div class="flex items-center gap-2.5">
      <!-- Dark mode toggle -->
      <button id="theme-toggle" aria-label="Toggle dark mode"
        class="w-9 h-9 rounded-full flex items-center justify-center text-stone-500 dark:text-stone-400 hover:bg-stone-100 dark:hover:bg-stone-800 transition-colors">
        <svg class="hidden dark:block w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
        </svg>
        <svg class="dark:hidden w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
        </svg>
      </button>

      <!-- Language toggle -->
      <div class="flex rounded-full overflow-hidden border border-stone-200 dark:border-stone-700 text-sm font-semibold">
        <button id="lang-de" class="lang-btn px-3.5 py-1.5 transition-colors" data-lang="de" aria-label="Deutsch">DE</button>
        <button id="lang-en" class="lang-btn px-3.5 py-1.5 transition-colors" data-lang="en" aria-label="English">EN</button>
      </div>

      <!-- Buchen CTA -->
      <a href="https://www.airbnb.de/rooms/1334011307998790600?utm_source=google_maps"
        target="_blank" rel="noopener noreferrer"
        class="hidden sm:inline-flex items-center gap-1.5 bg-[#FF5A5F] hover:bg-[#e04e53] text-white text-sm font-semibold px-4 py-1.5 rounded-full transition-colors shadow-sm">
        <span data-de>Buchen</span>
        <span data-en>Book</span>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      </a>
    </div>
  </div>
</header>

<script is:inline>
  // Dark mode
  document.getElementById('theme-toggle').addEventListener('click', function () {
    var isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  // Language toggle – only updates data-lang; CSS does the rest
  function applyLang(lang) {
    document.documentElement.setAttribute('data-lang', lang);
    document.documentElement.lang = lang;
    localStorage.setItem('lang', lang);

    document.querySelectorAll('.lang-btn').forEach(function (btn) {
      var active = btn.getAttribute('data-lang') === lang;
      btn.style.backgroundColor = active ? '#FF5A5F' : '';
      btn.style.color = active ? '#fff' : '';
    });
  }

  document.querySelectorAll('.lang-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      applyLang(btn.getAttribute('data-lang'));
    });
  });

  // Init
  applyLang(localStorage.getItem('lang') || 'de');
</script>
