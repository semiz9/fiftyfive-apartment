---
const googleMapsUrl = 'https://www.google.com/maps/dir/?api=1&destination=Gerngasse+2,+2391+Kaltenleutgeben,+%C3%96sterreich';
// OpenStreetMap embed – no API key needed, always works
// Coordinates for Gerngasse 2, 2391 Kaltenleutgeben (~48.0972, 16.0680)
const osmEmbed = 'https://www.openstreetmap.org/export/embed.html?bbox=16.048%2C48.077%2C16.088%2C48.117&layer=mapnik&marker=48.097%2C16.068';
---

<section id="location" class="py-20 px-4 bg-white dark:bg-stone-900/30">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-10">
      <span class="inline-block text-[#FF5A5F] text-sm font-semibold tracking-widest uppercase mb-3">
        <span data-de>Lage</span>
        <span data-en>Location</span>
      </span>
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-stone-900 dark:text-white">
        <span data-de>So finden Sie uns</span>
        <span data-en>How to find us</span>
      </h2>
      <p class="text-stone-500 dark:text-stone-400 mt-2 text-lg font-medium">
        Gerngasse 2/2, 2391 Kaltenleutgeben
      </p>
    </div>

    <div class="grid lg:grid-cols-5 gap-6 items-start">
      <!-- OpenStreetMap embed -->
      <div class="lg:col-span-3 rounded-2xl overflow-hidden shadow-md border border-stone-100 dark:border-stone-800" style="height:360px;">
        <iframe
          src={osmEmbed}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          title="Karte: Gerngasse 2/2, 2391 Kaltenleutgeben"
        ></iframe>
      </div>

      <!-- Info panel -->
      <div class="lg:col-span-2 space-y-4">
        <!-- Address card -->
        <div class="bg-stone-50 dark:bg-stone-900 border border-stone-100 dark:border-stone-800 rounded-2xl p-5">
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 rounded-xl bg-red-50 dark:bg-red-900/20 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-5 h-5 text-[#FF5A5F]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-stone-900 dark:text-white">Gerngasse 2/2</p>
              <p class="text-stone-500 dark:text-stone-400 text-sm">2391 Kaltenleutgeben</p>
              <p class="text-stone-400 dark:text-stone-500 text-sm">
                <span data-de>Niederösterreich, Österreich</span>
                <span data-en>Lower Austria, Austria</span>
              </p>
            </div>
          </div>
        </div>

        <!-- Directions button -->
        <a href={googleMapsUrl} target="_blank" rel="noopener noreferrer"
          class="flex items-center justify-center gap-2.5 bg-[#FF5A5F] hover:bg-[#e04e53] text-white font-semibold py-3.5 px-5 rounded-2xl transition-all hover:scale-[1.02] shadow-md">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
          <span data-de>Route in Google Maps planen</span>
          <span data-en>Get directions in Google Maps</span>
        </a>

        <!-- Transport details -->
        <div class="space-y-3">
          <div class="flex items-center gap-3 text-stone-600 dark:text-stone-300 text-sm">
            <div class="w-8 h-8 rounded-lg bg-blue-50 dark:bg-blue-900/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                <path d="M8 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM15 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/>
                <path d="M3 4a1 1 0 00-1 1v10a1 1 0 001 1h1.05a2.5 2.5 0 014.9 0H10a1 1 0 001-1V5a1 1 0 00-1-1H3zM14 7a1 1 0 00-1 1v6.05A2.5 2.5 0 0115.95 16H17a1 1 0 001-1v-5a1 1 0 00-.293-.707l-2-2A1 1 0 0015 7h-1z"/>
              </svg>
            </div>
            <span data-de>~25 Min. mit dem Auto von Wien</span>
            <span data-en>~25 min. by car from Vienna</span>
          </div>
          <div class="flex items-center gap-3 text-stone-600 dark:text-stone-300 text-sm">
            <div class="w-8 h-8 rounded-lg bg-emerald-50 dark:bg-emerald-900/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8"/>
              </svg>
            </div>
            <span data-de>Kostenloser Parkplatz vor dem Haus</span>
            <span data-en>Free parking in front of building</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
