---
---
<section id="book" class="py-24 px-4 bg-white dark:bg-stone-950 border-t border-stone-100 dark:border-stone-900">
  <div class="max-w-3xl mx-auto text-center">
    <!-- Icon -->
    <div class="w-16 h-16 rounded-full bg-red-50 dark:bg-red-900/20 flex items-center justify-center mx-auto mb-6">
      <svg class="w-8 h-8 text-[#FF5A5F]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
          d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
    </div>

    <h2 class="font-display text-stone-900 dark:text-white text-3xl sm:text-4xl md:text-5xl font-bold mb-4">
      <span data-de>Bereit für Ihren Aufenthalt?</span>
      <span data-en>Ready for your stay?</span>
    </h2>
    <p class="text-stone-500 dark:text-stone-400 text-lg mb-10 max-w-xl mx-auto">
      <span data-de>Buchen Sie jetzt direkt auf Airbnb. 90m² Natur & Komfort nahe Wien – für bis zu 6 Gäste.</span>
      <span data-en>Book now directly on Airbnb. 90m² of nature & comfort near Vienna – for up to 6 guests.</span>
    </p>

    <!-- Main CTA -->
    <a href="https://www.airbnb.de/rooms/1334011307998790600?utm_source=google_maps"
      target="_blank" rel="noopener noreferrer"
      class="group inline-flex items-center gap-3 bg-[#FF5A5F] hover:bg-[#e04e53] text-white font-bold text-lg px-10 py-4 rounded-2xl shadow-xl transition-all duration-200 hover:scale-105 hover:shadow-[#FF5A5F]/30">
      <svg class="w-5 h-5" viewBox="0 0 32 32" fill="currentColor">
        <path d="M16 1C7.716 1 1 7.716 1 16s6.716 15 15 15 15-6.716 15-15S24.284 1 16 1zm-.168 6.547c.28-.373.72-.613 1.176-.613.456 0 .896.24 1.176.613.28.373.384.86.272 1.336-.224.933-.896 1.96-1.448 2.52-.552-.56-1.224-1.587-1.448-2.52-.112-.476-.008-.963.272-1.336z"/>
      </svg>
      <span data-de>Jetzt buchen auf Airbnb</span>
      <span data-en>Book now on Airbnb</span>
      <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
      </svg>
    </a>

    <!-- Superhost badge -->
    <div class="flex justify-center mt-8">
      <div class="inline-flex items-center gap-3 bg-stone-50 dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-2xl px-5 py-3">
        <img src="/images/hd-airbnb-superhost-badge-logo-png-image-7017516947897882fy8exzval.png" alt="Airbnb Superhost" class="h-8 w-auto" />
        <div class="text-left">
          <p class="text-stone-900 dark:text-white font-bold text-sm">Kuzey Semiz</p>
          <p class="text-stone-500 dark:text-stone-400 text-xs">
            <span data-de>Airbnb Superhost · Verifiziert</span>
            <span data-en>Airbnb Superhost · Verified</span>
          </p>
        </div>
      </div>
    </div>

    <!-- Trust signals -->
    <div class="flex flex-wrap justify-center gap-6 mt-6 text-stone-400 dark:text-stone-500 text-sm">
      <div class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-emerald-500" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        <span data-de>Airbnb Zahlungsschutz</span>
        <span data-en>Airbnb Payment Protection</span>
      </div>
      <div class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
        <span data-de>4.8 Sterne Bewertung</span>
        <span data-en>4.8 Star Rating</span>
      </div>
      <div class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-[#FF5A5F]" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l3-3z" clip-rule="evenodd"/>
        </svg>
        <span data-de>Sofortbuchung möglich</span>
        <span data-en>Instant booking available</span>
      </div>
    </div>
  </div>
</section>
