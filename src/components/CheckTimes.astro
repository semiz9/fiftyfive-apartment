---
---
<section id="times" class="py-16 px-4 bg-stone-900 dark:bg-stone-950">
  <div class="max-w-4xl mx-auto">
    <div class="flex flex-col sm:flex-row items-center justify-center gap-6 sm:gap-0">

      <!-- Check-in -->
      <div class="flex-1 flex flex-col items-center text-center text-white">
        <div class="w-14 h-14 rounded-2xl bg-white/10 flex items-center justify-center mb-3">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
              d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
          </svg>
        </div>
        <p class="text-white/60 text-xs font-semibold uppercase tracking-widest mb-1">
          <span data-de>Anreise</span>
          <span data-en>Check-in</span>
        </p>
        <p class="text-5xl font-bold font-display text-[#FF5A5F]">15:00</p>
        <p class="text-white/50 text-sm mt-1">
          <span data-de>ab 15:00 Uhr</span>
          <span data-en>from 3:00 PM</span>
        </p>
      </div>

      <!-- Divider -->
      <div class="hidden sm:flex flex-col items-center px-10">
        <div class="w-px h-12 bg-white/10"></div>
        <div class="w-7 h-7 rounded-full border border-white/20 flex items-center justify-center my-2">
          <svg class="w-3.5 h-3.5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
        <div class="w-px h-12 bg-white/10"></div>
      </div>
      <div class="sm:hidden w-12 h-px bg-white/20"></div>

      <!-- Check-out -->
      <div class="flex-1 flex flex-col items-center text-center text-white">
        <div class="w-14 h-14 rounded-2xl bg-white/10 flex items-center justify-center mb-3">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
              d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
          </svg>
        </div>
        <p class="text-white/60 text-xs font-semibold uppercase tracking-widest mb-1">
          <span data-de>Abreise</span>
          <span data-en>Check-out</span>
        </p>
        <p class="text-5xl font-bold font-display text-[#FF5A5F]">12:00</p>
        <p class="text-white/50 text-sm mt-1">
          <span data-de>bis 12:00 Uhr</span>
          <span data-en>by 12:00 PM</span>
        </p>
      </div>
    </div>

    <p class="text-center text-white/30 text-sm mt-10">
      <span data-de>Früheres Check-in oder späteres Check-out auf Anfrage möglich.</span>
      <span data-en>Early check-in or late check-out available on request.</span>
    </p>
  </div>
</section>
