---
const images = [
  { src: '/images/apartment-1.avif', alt: 'Wohnzimmer – Living Room' },
  { src: '/images/apartment-2.avif', alt: 'Schlafzimmer – Bedroom' },
  { src: '/images/apartment-3.avif', alt: 'Küche – Kitchen' },
  { src: '/images/apartment-4.avif', alt: 'Bad – Bathroom' },
  { src: '/images/apartment-5.avif', alt: 'Ausblick – View' },
];
---

<section id="hero" class="relative w-full h-screen min-h-[600px] overflow-hidden">
  <!-- Swiper container -->
  <div class="swiper hero-swiper absolute inset-0 w-full h-full">
    <div class="swiper-wrapper">
      {images.map(img => (
        <div class="swiper-slide relative">
          <img src={img.src} alt={img.alt} class="w-full h-full object-cover" loading="eager" />
          <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/30 to-black/75"></div>
        </div>
      ))}
    </div>
    <!-- Pagination -->
    <div class="swiper-pagination" style="bottom: 140px;"></div>
    <!-- Navigation -->
    <div class="swiper-button-prev"></div>
    <div class="swiper-button-next"></div>
  </div>

  <!-- Hero content -->
  <div class="absolute inset-0 flex flex-col items-center justify-end pb-16 sm:pb-20 px-4 text-center z-10 pointer-events-none">
    <div class="pointer-events-auto">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-black/40 text-white text-xs font-semibold px-3 py-1.5 rounded-full mb-4 backdrop-blur-sm">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
        </svg>
        Kaltenleutgeben · nahe Wien
      </div>

      <!-- Title -->
      <h1 class="font-display text-white text-4xl sm:text-5xl md:text-6xl font-bold leading-tight mb-3 drop-shadow-lg">
        <span data-de>Natur & Komfort<br>nahe Wien – 90m²</span>
        <span data-en>Nature & Comfort<br>near Vienna – 90m²</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-white/90 text-lg sm:text-xl mb-8 drop-shadow">
        <span data-de>Für bis zu 6 Gäste</span>
        <span data-en>For up to 6 guests</span>
      </p>

      <!-- CTA Button -->
      <a href="https://www.airbnb.de/rooms/1334011307998790600?utm_source=google_maps"
        target="_blank" rel="noopener noreferrer"
        class="group inline-flex items-center gap-2.5 bg-[#FF5A5F] hover:bg-[#e04e53] text-white font-bold text-base sm:text-lg px-7 py-3.5 rounded-2xl shadow-2xl transition-all duration-200 hover:scale-105">
        <svg class="w-5 h-5" viewBox="0 0 32 32" fill="currentColor">
          <path d="M16 1C7.716 1 1 7.716 1 16s6.716 15 15 15 15-6.716 15-15S24.284 1 16 1zm-.168 6.547c.28-.373.72-.613 1.176-.613.456 0 .896.24 1.176.613.28.373.384.86.272 1.336-.224.933-.896 1.96-1.448 2.52-.552-.56-1.224-1.587-1.448-2.52-.112-.476-.008-.963.272-1.336z"/>
        </svg>
        <span data-de>Jetzt buchen auf Airbnb</span>
        <span data-en>Book now on Airbnb</span>
        <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-5 left-1/2 -translate-x-1/2 z-10 animate-bounce opacity-60 pointer-events-none">
    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>

<script>
  import Swiper from 'swiper';
  import { Navigation, Pagination, Autoplay } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/navigation';
  import 'swiper/css/pagination';

  new Swiper('.hero-swiper', {
    modules: [Navigation, Pagination, Autoplay],
    loop: true,
    autoplay: {
      delay: 17000,
      disableOnInteraction: false,
      pauseOnMouseEnter: true,
    },
    pagination: {
      el: '.swiper-pagination',
      clickable: true,
    },
    navigation: {
      nextEl: '.swiper-button-next',
      prevEl: '.swiper-button-prev',
    },
    grabCursor: true,
    speed: 800,
  });
</script>
