---
const reviews = [
  {
    name: 'Yokohama',
    since: '3 Jahren auf Airbnb',
    sinceEn: '3 years on Airbnb',
    date: 'Jänner 2026',
    dateEn: 'January 2026',
    rating: 5,
    textDe: 'Die Unterkunft war geräumig, sauber und sehr gepflegt. Alles war komfortabel und genau wie beschrieben. Wir hatten einen tollen Aufenthalt und würden diese Unterkunft auf jeden Fall empfehlen.',
    textEn: 'The accommodation was spacious, clean and very well-maintained. Everything was comfortable and exactly as described. We had a great stay and would definitely recommend this accommodation.',
    avatar: 'Y',
    avatarBg: '#F59E0B',
  },
  {
    name: 'NurulBadiah',
    since: '9 Jahren auf Airbnb',
    sinceEn: '9 years on Airbnb',
    date: 'Jänner 2026',
    dateEn: 'January 2026',
    rating: 5,
    textDe: 'Ein sehr sauberes, gemütliches und geräumiges Zuhause, in dem wir uns wie bei uns zu Hause fühlten. Der Besitzer war äußerst freundlich und reaktionsschnell, was unseren Aufenthalt noch komfortabler machte. Ich würde diese Unterkunft definitiv anderen empfehlen.',
    textEn: 'A very clean, cozy and spacious home where we felt right at home. The host was extremely friendly and responsive, which made our stay even more comfortable. I would definitely recommend this accommodation to others.',
    avatar: 'N',
    avatarBg: '#0D9488',
  },
];

const avgRating = 4.8;
---

<section id="reviews" class="py-20 px-4 bg-stone-50 dark:bg-stone-950">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <span class="inline-block text-[#FF5A5F] text-sm font-semibold tracking-widest uppercase mb-3">
        <span data-de>Gästebewertungen</span>
        <span data-en>Guest Reviews</span>
      </span>
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-stone-900 dark:text-white">
        <span data-de>Was unsere Gäste sagen</span>
        <span data-en>What our guests say</span>
      </h2>

      <!-- Superhost badge -->
      <div class="flex flex-wrap justify-center gap-3 mt-5">
        <div class="inline-flex items-center gap-2.5 bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-700 rounded-full px-5 py-2.5 shadow-sm">
          <img src="/images/hd-airbnb-superhost-badge-logo-png-image-7017516947897882fy8exzval.png" alt="Airbnb Superhost" class="h-7 w-auto" />
          <span class="text-stone-700 dark:text-stone-300 font-semibold text-sm">
            <span data-de>Verifizierter Superhost</span>
            <span data-en>Verified Superhost</span>
          </span>
        </div>

      <!-- Average rating badge -->
      <div class="inline-flex items-center gap-2.5 bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-700 rounded-full px-5 py-2.5 shadow-sm">
        <span class="text-2xl font-bold text-stone-900 dark:text-white">{avgRating}</span>
        <div class="flex gap-0.5">
          {[1,2,3,4,5].map(s => (
            <svg class={`w-4 h-4 ${s <= Math.round(avgRating) ? 'text-amber-400' : 'text-stone-200 dark:text-stone-600'}`}
                 fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>
        <span class="text-stone-500 dark:text-stone-400 text-sm">
          <span data-de>· Airbnb Durchschnitt</span>
          <span data-en>· Airbnb average</span>
        </span>
      </div>
      </div><!-- end flex badges -->
    </div>

    <div class="grid sm:grid-cols-2 gap-5">
      {reviews.map(r => (
        <article class="bg-white dark:bg-stone-900 border border-stone-100 dark:border-stone-800 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">
          <!-- Reviewer -->
          <div class="flex items-center gap-3 mb-4">
            <div class="w-11 h-11 rounded-full flex items-center justify-center text-white font-bold text-lg flex-shrink-0"
                 style={`background-color: ${r.avatarBg}`}>
              {r.avatar}
            </div>
            <div>
              <p class="font-semibold text-stone-900 dark:text-white">{r.name}</p>
              <p class="text-stone-400 text-xs">
                <span data-de>Seit {r.since}</span>
                <span data-en>Since {r.sinceEn}</span>
              </p>
            </div>
          </div>

          <!-- Stars + date -->
          <div class="flex items-center gap-2 mb-3">
            <div class="flex gap-0.5">
              {[1,2,3,4,5].map(s => (
                <svg class={`w-4 h-4 ${s <= r.rating ? 'text-amber-400' : 'text-stone-200'}`}
                     fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <span class="text-stone-300 text-sm">·</span>
            <span class="text-stone-400 text-sm">
              <span data-de>{r.date}</span>
              <span data-en>{r.dateEn}</span>
            </span>
          </div>

          <!-- Text -->
          <p class="text-stone-600 dark:text-stone-300 text-sm sm:text-base leading-relaxed">
            <span data-de>{r.textDe}</span>
            <span data-en>{r.textEn}</span>
          </p>

          <!-- Airbnb badge -->
          <div class="flex items-center gap-1.5 mt-4 text-stone-400 text-xs">
            <svg class="w-3.5 h-3.5 text-[#FF5A5F]" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zm5.328 9.416l-6.208 6.208a.75.75 0 01-1.06 0L6.672 12.24a.75.75 0 011.06-1.06l2.858 2.858 5.678-5.678a.75.75 0 011.06 1.056z"/>
            </svg>
            <span data-de>Verifiziert via Airbnb</span>
            <span data-en>Verified via Airbnb</span>
          </div>
        </article>
      ))}
    </div>

    <!-- All reviews link -->
    <div class="text-center mt-8">
      <a href="https://www.airbnb.de/rooms/1334011307998790600?utm_source=google_maps#reviews"
        target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-[#FF5A5F] hover:text-[#e04e53] font-medium text-sm transition-colors">
        <span data-de>Alle Bewertungen auf Airbnb ansehen</span>
        <span data-en>View all reviews on Airbnb</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      </a>
    </div>
  </div>
</section>
