---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Fiftyfive Apartments – Natur & Komfort nahe Wien | Kaltenleutgeben',
  description = 'Geräumiges 90m² Apartment in Kaltenleutgeben nahe Wien. Für bis zu 6 Gäste. Self Check-in, WLAN 150 Mbit, Küche, Parkplatz.',
} = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "LodgingBusiness",
  "name": "Fiftyfive Apartments",
  "description": description,
  "url": "https://semiz-kaltenleutgeben.pages.dev",
  "telephone": "+4367655581000",
  "email": "semizbnb@outlook.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Gerngasse 2/2",
    "addressLocality": "Kaltenleutgeben",
    "postalCode": "2391",
    "addressCountry": "AT"
  },
  "checkinTime": "15:00",
  "checkoutTime": "12:00",
  "occupancy": { "@type": "QuantitativeValue", "maxValue": 6 }
};
---

<!DOCTYPE html>
<html lang="de" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="author" content="Kuzey Semiz" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="/images/apartment-1.avif" />

  <!-- PWA -->
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#FF5A5F" />
  <meta name="apple-mobile-web-app-capable" content="yes" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet" />


  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>

  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- FOUC prevention: dark mode + language -->
  <script is:inline>
    (function () {
      // Dark mode
      var saved = localStorage.getItem('theme');
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (saved === 'dark' || (!saved && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
      // Language – set data-lang immediately so CSS rules apply before paint
      var lang = localStorage.getItem('lang') || 'de';
      document.documentElement.setAttribute('data-lang', lang);
      document.documentElement.lang = lang;
    })();
  </script>
</head>
<body class="bg-white dark:bg-stone-950 text-stone-800 dark:text-stone-100 transition-colors duration-300 font-sans">
  <slot />
</body>
</html>

<!-- Global i18n via CSS – no JS forEach needed, no class="hidden" conflicts -->
<style is:global>
  /* Hide EN content by default (German is default) */
  [data-en] { display: none; }

  /* When page lang is EN: show EN, hide DE */
  html[data-lang='en'] [data-en] { display: revert; }
  html[data-lang='en'] [data-de] { display: none !important; }

  /* Swiper arrow colors */
  .swiper-button-prev,
  .swiper-button-next { color: white !important; }
  .swiper-button-prev::after,
  .swiper-button-next::after { font-size: 1.5rem !important; }
</style>
